{
  "name": "@nyuchi/ui",
  "version": "0.2.0",
  "description": "Svelte 5 / SvelteKit component library for the Nyuchi Design System — accessible primitives on the seven African-mineral tokens. Nyuchi's implementation of the Mzizi architecture.",
  "type": "module",
  "license": "MIT",
  "author": "Nyuchi Africa (Pvt) Ltd",
  "homepage": "https://github.com/nyuchi/packages-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nyuchi/packages-ui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/nyuchi/packages-ui/issues"
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./styles/globals.css": "./styles/globals.css",
    "./styles/brand-bundu.css": "./styles/brand-bundu.css",
    "./styles/brand-nyuchi.css": "./styles/brand-nyuchi.css",
    "./styles/brand-mukoko.css": "./styles/brand-mukoko.css",
    "./tailwind-preset": "./tailwind-preset.mjs"
  },
  "files": [
    "dist",
    "styles",
    "tailwind-preset.mjs"
  ],
  "scripts": {
    "build": "svelte-package",
    "prepack": "svelte-package",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "peerDependencies": {
    "svelte": "^5"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nyuchi",
    "mzizi",
    "design-system",
    "svelte",
    "sveltekit",
    "ui"
  ]
}
